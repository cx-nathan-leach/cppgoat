{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "cmake --build --preset=conan-debug",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Release",
      "type": "shell",
      "command": "cmake --build --preset=conan-release"
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "cmake --build --preset=conan-release --target clean;cmake --build --preset=conan-debug --target clean"
    }
  ]
}